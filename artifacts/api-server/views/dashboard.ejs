<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>XiFil Hub – Dashboard</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#0A0A0F;color:#E0E0E0;font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh}
    nav{background:#0F0F1A;border-bottom:1px solid #1E1E30;padding:0 32px;
      display:flex;align-items:center;justify-content:space-between;height:60px}
    .nav-brand{font-weight:800;font-size:1.1rem;
      background:linear-gradient(135deg,#00C3FF,#0080FF);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .nav-right{display:flex;align-items:center;gap:16px}
    .avatar{width:32px;height:32px;border-radius:50%;border:2px solid #00C3FF22;object-fit:cover}
    .avatar-placeholder{width:32px;height:32px;border-radius:50%;
      background:#1E1E30;display:flex;align-items:center;justify-content:center;
      font-size:.8rem;color:#00C3FF;font-weight:700;border:2px solid #00C3FF22}
    .username{font-size:.9rem;color:#888}
    .logout-btn{background:transparent;border:1px solid #2A2A3A;color:#888;
      border-radius:8px;padding:6px 14px;font-size:.82rem;cursor:pointer;
      text-decoration:none;transition:border-color .15s,color .15s}
    .logout-btn:hover{border-color:#FF4C4C;color:#FF4C4C}
    main{max-width:800px;margin:0 auto;padding:40px 24px}
    h1{font-size:1.6rem;font-weight:700;margin-bottom:4px}
    .subtitle{color:#555;font-size:.9rem;margin-bottom:32px}
    .alert{border-radius:10px;padding:12px 16px;font-size:.88rem;margin-bottom:20px;border:1px solid}
    .alert-success{background:#0A1A0A;border-color:#00C3FF33;color:#00C3FF}
    .alert-error{background:#1A0A0A;border-color:#FF4C4C33;color:#FF6B6B}
    .card{background:#141420;border:1px solid #1E1E30;border-radius:16px;padding:28px;margin-bottom:20px}
    .card-title{font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;color:#555;margin-bottom:16px}
    .key-box{background:#0A0A0F;border:1.5px solid #00C3FF;border-radius:10px;padding:16px 20px;
      font-family:'Courier New',monospace;font-size:1.1rem;font-weight:700;color:#00C3FF;
      word-break:break-all;cursor:pointer;user-select:all;transition:background .15s;margin-bottom:12px}
    .key-box:hover{background:#0D0D15}
    .key-meta{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px}
    .meta-badge{background:#1A1A28;border:1px solid #2A2A3A;border-radius:6px;
      padding:4px 10px;font-size:.75rem;color:#888}
    .meta-badge span{color:#00C3FF;font-weight:600}
    .btn-row{display:flex;gap:10px;flex-wrap:wrap}
    .btn{border:none;border-radius:8px;padding:10px 20px;font-size:.88rem;
      font-weight:700;cursor:pointer;transition:opacity .15s;text-decoration:none;
      display:inline-flex;align-items:center;gap:6px}
    .btn:hover{opacity:.85}
    .btn-cyan{background:#00C3FF;color:#0A0A0F}
    .btn-ghost{background:transparent;border:1px solid #2A2A3A;color:#888}
    .btn-ghost:hover{border-color:#00C3FF;color:#00C3FF;opacity:1}
    .btn-danger{background:transparent;border:1px solid #2A2A3A;color:#888}
    .btn-danger:hover{border-color:#FF4C4C;color:#FF4C4C;opacity:1}
    .no-key{text-align:center;padding:40px 0}
    .no-key p{color:#555;margin-bottom:20px;font-size:.95rem}
    .hwid-form{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap}
    .hwid-input{flex:1;min-width:200px;background:#0A0A0F;border:1px solid #2A2A3A;
      border-radius:8px;padding:10px 14px;color:#E0E0E0;font-size:.9rem;outline:none}
    .hwid-input:focus{border-color:#00C3FF}
    .hwid-input::placeholder{color:#444}
    .info-box{background:#0F0F1A;border:1px solid #1E1E30;border-radius:10px;
      padding:16px;font-size:.82rem;color:#555;line-height:1.6}
    .info-box a{color:#00C3FF}
  </style>
</head>
<body>
  <nav>
    <div class="nav-brand">⚡ XiFil Hub</div>
    <div class="nav-right">
      <% if (user.avatar) { %>
        <img src="<%= user.avatar %>" class="avatar" alt="avatar"/>
      <% } else { %>
        <div class="avatar-placeholder"><%= user.username.charAt(0).toUpperCase() %></div>
      <% } %>
      <span class="username"><%= user.username %></span>
      <% if (user.role === 'admin') { %>
        <a href="/xifil-admin" class="logout-btn" style="border-color:#00C3FF33;color:#00C3FF">⚙️ Admin</a>
      <% } %>
      <a href="/auth/logout" class="logout-btn">Logout</a>
    </div>
  </nav>

  <main>
    <h1>👋 Halo, <%= user.username %>!</h1>
    <p class="subtitle">Member Panel — XiFil Key System</p>

    <% if (success === 'hwid_reset') { %>
      <div class="alert alert-success">✅ HWID berhasil direset! Key kamu sekarang bisa digunakan di device baru.</div>
    <% } %>
    <% if (error === 'hwid_required') { %>
      <div class="alert alert-error">❌ Masukkan HWID terlebih dahulu sebelum mengambil key.</div>
    <% } %>
    <% if (error === 'config_error') { %>
      <div class="alert alert-error">❌ Server error. Hubungi admin.</div>
    <% } %>

    <div class="card">
      <div class="card-title">🔑 Key Aktif Kamu</div>

      <% if (activeKey) { %>
        <div class="key-box" id="keyText" onclick="copyKey()"><%= activeKey.key %></div>
        <div class="key-meta">
          <div class="meta-badge">Type: <span><%= activeKey.type ? activeKey.type.toUpperCase() : 'FREE' %></span></div>
          <div class="meta-badge">Sisa: <span><%= timeLeft %></span></div>
          <% if (activeKey.hwid) { %>
            <div class="meta-badge">HWID: <span><%= activeKey.hwid.substring(0,12) %>...</span></div>
          <% } %>
        </div>
        <div class="btn-row">
          <button class="btn btn-cyan" onclick="copyKey()">📋 Copy Key</button>
          <form action="/dashboard/reset-hwid" method="POST" style="display:inline">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Reset HWID? Key bisa digunakan di device baru.')">🔄 Reset HWID</button>
          </form>
        </div>
      <% } else { %>
        <div class="no-key">
          <p>Kamu belum punya key aktif.<br/>Masukkan HWID Roblox kamu dan klik "Get Free Key".</p>
          <form class="hwid-form" action="/dashboard/get-free-key" method="GET">
            <input class="hwid-input" type="text" name="hwid" placeholder="Masukkan HWID Roblox kamu..." required/>
            <button type="submit" class="btn btn-cyan">🎁 Get Free Key</button>
          </form>
          <div class="info-box">
            💡 <strong>Cara dapatkan HWID:</strong><br/>
            Di Roblox, jalankan script: <code style="color:#00C3FF;font-size:.78rem">print(game:GetService("RbxAnalyticsService"):GetClientId())</code><br/>
            Copy hasilnya dan paste di atas. Key gratis berlaku 24 jam.
          </div>
        </div>
      <% } %>
    </div>

    <div class="card">
      <div class="card-title">ℹ️ Informasi Akun</div>
      <div class="key-meta">
        <div class="meta-badge">Discord ID: <span><%= user.discordId %></span></div>
        <div class="meta-badge">Role: <span><%= user.role.toUpperCase() %></span></div>
      </div>
    </div>
  </main>

  <script>
    function copyKey(){
      const text=document.getElementById('keyText');
      if(!text)return;
      navigator.clipboard.writeText(text.innerText).then(()=>{
        text.style.borderColor='#00FF88';
        setTimeout(()=>{text.style.borderColor='#00C3FF'},1500);
      });
    }
  </script>
</body>
</html>
