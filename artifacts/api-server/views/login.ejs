<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>XiFil Hub – Login</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#0A0A0F;color:#E0E0E0;font-family:'Segoe UI',system-ui,sans-serif;
      min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
      padding:24px;overflow:hidden}
    .glow{position:fixed;top:-200px;left:50%;transform:translateX(-50%);
      width:600px;height:400px;background:radial-gradient(ellipse,rgba(0,195,255,.12) 0%,transparent 70%);
      pointer-events:none}
    .card{background:#141420;border:1px solid #1E1E30;border-radius:20px;padding:52px 44px;
      max-width:440px;width:100%;text-align:center;position:relative;z-index:1;
      box-shadow:0 0 60px rgba(0,195,255,.06)}
    .logo{font-size:2.5rem;margin-bottom:8px}
    .brand{font-size:1.8rem;font-weight:800;letter-spacing:-.03em;
      background:linear-gradient(135deg,#00C3FF,#0080FF);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .tagline{color:#555;font-size:.9rem;margin-top:6px;margin-bottom:36px}
    .feature-list{list-style:none;text-align:left;margin-bottom:36px;
      background:#0F0F1A;border-radius:12px;padding:20px 24px;border:1px solid #1E1E30}
    .feature-list li{color:#888;font-size:.88rem;padding:5px 0;display:flex;align-items:center;gap:10px}
    .feature-list li span{color:#00C3FF;font-size:1rem}
    .discord-btn{display:inline-flex;align-items:center;gap:12px;
      background:linear-gradient(135deg,#5865F2,#4752C4);color:#fff;text-decoration:none;
      border-radius:12px;padding:14px 28px;font-size:1rem;font-weight:700;
      width:100%;justify-content:center;transition:opacity .2s,transform .1s;border:none;cursor:pointer}
    .discord-btn:hover{opacity:.9;transform:translateY(-1px)}
    .discord-btn:active{transform:translateY(0)}
    .discord-icon{width:24px;height:24px;fill:white}
    .error-msg{background:#1A1010;border:1px solid #3A1A1A;color:#FF6B6B;
      border-radius:8px;padding:10px 14px;font-size:.85rem;margin-bottom:20px}
    .footer{margin-top:28px;font-size:.75rem;color:#333}
  </style>
</head>
<body>
  <div class="glow"></div>
  <div class="card">
    <div class="logo">⚡</div>
    <div class="brand">XiFil Hub</div>
    <p class="tagline">KIIBOO Key System — Aman & Terpercaya</p>
    <% if (error) { %>
      <div class="error-msg">
        <% if (error === 'access_denied') { %>
          ❌ Kamu membatalkan proses login Discord.
        <% } else if (error === 'no_code') { %>
          ❌ Discord tidak mengirim kode otorisasi. Coba lagi.
        <% } else if (error === 'token_exchange') { %>
          ❌ Gagal tukar kode dengan Discord.<br/>
          <small style="opacity:.7">Kemungkinan: Client Secret salah atau Redirect URI belum didaftarkan di Discord Developer Portal.</small>
          <% if (typeof detail !== 'undefined' && detail) { %>
            <br/><code style="font-size:.75rem;opacity:.5"><%= detail %></code>
          <% } %>
        <% } else if (error === 'fetch_user') { %>
          ❌ Gagal mengambil data akun Discord kamu.<br/>
          <small style="opacity:.7">Token tidak valid atau Discord API sedang bermasalah.</small>
          <% if (typeof detail !== 'undefined' && detail) { %>
            <br/><code style="font-size:.75rem;opacity:.5"><%= detail %></code>
          <% } %>
        <% } else if (error === 'db_error') { %>
          ❌ Gagal menyimpan sesi login.<br/>
          <small style="opacity:.7">Kemungkinan: Database (Neon) tidak terhubung atau tabel belum dibuat.</small>
          <% if (typeof detail !== 'undefined' && detail) { %>
            <br/><code style="font-size:.75rem;opacity:.5"><%= detail %></code>
          <% } %>
        <% } else { %>
          ❌ Login gagal (<%= error %>). Silakan coba lagi.
        <% } %>
      </div>
    <% } %>
    <ul class="feature-list">
      <li><span>🔑</span> Free Key via iklan setiap 24 jam</li>
      <li><span>🛡️</span> HWID & Discord binding protection</li>
      <li><span>📊</span> Dashboard key management</li>
      <li><span>🔒</span> Anti-bypass checkpoint system</li>
    </ul>
    <a href="/auth/discord" class="discord-btn">
      <svg class="discord-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.063.103 18.07.11 18.073a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
      </svg>
      Login dengan Discord
    </a>
    <p class="footer">© 2026 XiFil Hub. All rights reserved.</p>
  </div>
</body>
</html>
